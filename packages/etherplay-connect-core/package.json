{
	"name": "@etherplay/connect-core",
	"version": "0.0.0",
	"description": "core functionality for @etherplay/connect and other",
	"homepage": "https://github.com/wighawag/etherplay-connect#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/etherplay-connect.git",
		"directory": "packages/etherplay-connect-utils"
	},
	"bugs": {
		"url": "https://github.com/wighawag/etherplay-connect/issues"
	},
	"author": "Ronan Sandford",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"dependencies": {
		"@noble/curves": "^1.8.1",
		"@noble/hashes": "^1.7.1",
		"@noble/secp256k1": "^2.2.3",
		"@scure/bip32": "^1.6.2",
		"@scure/bip39": "^1.5.4"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.0.18",
		"as-soon": "^0.0.11",
		"eip-1193": "^0.6.3",
		"ldenv": "^0.3.12",
		"prettier": "^3.5.3",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"dev": "as-soon -w src pnpm build",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"test:watch": "vitest",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	}
}
