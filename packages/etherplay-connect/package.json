{
	"name": "@etherplay/connect",
	"version": "0.0.48",
	"description": "Main connection library for Etherplay Accounts - provides seamless wallet and social authentication with session account management",
	"keywords": [
		"web3",
		"wallet",
		"authentication",
		"ethereum",
		"session",
		"social-login",
		"oauth",
		"mnemonic",
		"email-login",
		"svelte",
		"typescript",
		"eip-6963",
		"wallet-connect",
		"account-kit"
	],
	"homepage": "https://github.com/wighawag/etherplay-connect#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/etherplay-connect.git",
		"directory": "packages/etherplay-connect"
	},
	"bugs": {
		"url": "https://github.com/wighawag/etherplay-connect/issues"
	},
	"author": "Ronan Sandford",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"dependencies": {
		"@etherplay/connect-core": "workspace:*",
		"@etherplay/wallet-connector": "workspace:*",
		"@etherplay/wallet-connector-ethereum": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.0.18",
		"as-soon": "^0.0.11",
		"eip-1193": "^0.6.3",
		"ldenv": "^0.3.12",
		"prettier": "^3.5.3",
		"svelte": "^5.25.12",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"dev": "as-soon -w src pnpm build",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"test:watch": "vitest",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	}
}
