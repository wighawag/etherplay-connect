{
  "name": "etherplay-connect-monorepo",
  "private": true,
  "description": "Wallet Connection VIa Session Account",
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "set-defaults": "^0.0.5",
    "zellij-launcher": "^0.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "prepare": "set-defaults .vscode && pnpm build:packages",
    "build:packages": "pnpm build:etherplay-alchemy && pnpm build:etherplay-connect",
    "build:etherplay-alchemy": "pnpm run --filter @etherplay/alchemy build",
    "build:etherplay-connect": "pnpm run --filter @etherplay/connect build",
    "build:web": "pnpm run --filter ./web build",
    "build": "pnpm '/^build:.*/'",
    "build:demo": "pnpm run build:packages && pnpm run --filter ./demoes/sveltekit build",
    "build-and-merge": "pnpm build:demo && pnpm build:web && cp -r ./demoes/sveltekit/build web/dist/demo",
    "start": "zellij-launcher --layout zellij.kdl a $npm_package_name || zellij --layout zellij.kdl -s $npm_package_name",
    "dev": "pnpm run --parallel -r dev"
  }
}