{
  "name": "etherplay-account-monorepo",
  "private": true,
  "description": "Wallet Connection VIa Session Account",
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "set-defaults": "^0.0.5",
    "zellij-launcher": "^0.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "prepare": "set-defaults .vscode && pnpm build:packages",
    "build:packages": "pnpm run --filter './packages/**' build",
    "build:web": "pnpm run --filter @renraku/web build",
    "build": "pnpm '/^build:.*/'",
    "build-only-demo": "pnpm run build:packages && pnpm run --filter ./demoes/sveltekit build",
    "start": "zellij-launcher --layout zellij.kdl a $npm_package_name || zellij --layout zellij.kdl -s $npm_package_name",
    "dev": "pnpm run --parallel -r dev"
  }
}